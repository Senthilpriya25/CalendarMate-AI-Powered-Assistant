        "jsCode": "// Response Formatter\n// Collects output from whichever agent ran and formats it for the chat interface\n\nconst items = $input.all();\nconst item = items[0];\n\nlet responseText = '';\nlet source = 'unknown';\n\n// Try to get output from various possible field names\nif (item.json.output) {\n  responseText = item.json.output;\n  source = 'agent';\n} else if (item.json.text) {\n  responseText = item.json.text;\n  source = 'text';\n} else if (item.json.message) {\n  responseText = item.json.message;\n  source = 'message';\n} else if (item.json.htmlLink) {\n  // This is a calendar event creation response\n  responseText = `✅ Meeting created successfully!\\n\\n📅 **Event:** ${item.json.summary || 'New Meeting'}\\n🕐 **Time:** ${item.json.start?.dateTime || 'TBD'} – ${item.json.end?.dateTime || 'TBD'}\\n🔗 **Google Meet:** ${item.json.hangoutLink || 'Link will be in your calendar invite'}\\n📧 **Calendar invite sent to all attendees.**\\n\\nView it here: ${item.json.htmlLink}`;\n  source = 'calendar_create';\n} else {\n  responseText = 'I processed your request but could not generate a response. Please try again.';\n}\n\nreturn [{\n  json: {\n    response: responseText,\n    source: source,\n    timestamp: new Date().toISOString()\n  }\n}];"
